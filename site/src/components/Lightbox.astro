<div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90">
  <button id="lb-close" type="button" class="absolute top-3 right-4 text-white/90 hover:text-white text-4xl leading-none" aria-label="閉じる">&times;</button>
  <button id="lb-prev" type="button" class="absolute left-2 sm:left-4 text-white/80 hover:text-white text-5xl leading-none px-3 py-2 select-none" aria-label="前の写真">&lsaquo;</button>
  <img id="lb-img" src="" alt="" class="max-h-[90vh] max-w-[92vw] object-contain rounded" />
  <button id="lb-next" type="button" class="absolute right-2 sm:right-4 text-white/80 hover:text-white text-5xl leading-none px-3 py-2 select-none" aria-label="次の写真">&rsaquo;</button>
</div>
<script is:inline>
  (function () {
    var lb = document.getElementById('lightbox');
    if (!lb) return;
    var img = document.getElementById('lb-img');
    var items = Array.prototype.slice.call(document.querySelectorAll('.lb-item'));
    if (!items.length) return;
    var idx = -1;
    function show(i) {
      idx = (i + items.length) % items.length;
      img.src = items[idx].getAttribute('data-full');
      lb.classList.remove('hidden');
      lb.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      lb.classList.add('hidden');
      lb.classList.remove('flex');
      img.src = '';
      document.body.style.overflow = '';
    }
    items.forEach(function (el, i) { el.addEventListener('click', function () { show(i); }); });
    document.getElementById('lb-close').addEventListener('click', close);
    document.getElementById('lb-prev').addEventListener('click', function (e) { e.stopPropagation(); show(idx - 1); });
    document.getElementById('lb-next').addEventListener('click', function (e) { e.stopPropagation(); show(idx + 1); });
    lb.addEventListener('click', function (e) { if (e.target === lb) close(); });
    document.addEventListener('keydown', function (e) {
      if (lb.classList.contains('hidden')) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') show(idx - 1);
      else if (e.key === 'ArrowRight') show(idx + 1);
    });
  })();
</script>
